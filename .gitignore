# Only ignore CSV and PNG files, keep the folders
data/*.csv
!data/.gitkeep

outputs/*.png
outputs/*.html
!outputs/.gitkeep

images/*.png
!images/.gitkeep

# IDE
.vscode/
.idea/
.idea/
*.swp
*.swo
*~
.DS_Store

# Project specific
data/*.csv
outputs/*.png
outputs/*.html
outputs/*.txt
outputs/*.csv
